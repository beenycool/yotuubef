# Environment Variables Configuration Template
# Copy this file to .env and fill in your actual credentials

# Reddit API credentials
REDDIT_CLIENT_ID="your_reddit_client_id_here"
REDDIT_CLIENT_SECRET="your_reddit_client_secret_here"

# NVIDIA NIM API key (https://build.nvidia.com/)
NVIDIA_NIM_API_KEY="your_nvidia_nim_api_key_here"

# Hack Club Search API key
HACKCLUB_SEARCH_API_KEY="your_hackclub_search_api_key_here"

# YouTube OAuth
# Path to the client_secret.json downloaded from Google Cloud Console for OAuth fallback
GOOGLE_CLIENT_SECRETS_FILE="path/to/client_secret.json"
# Path where OAuth token will be stored
YOUTUBE_TOKEN_FILE="youtube_token.json"
# YouTube OAuth token JSON (alternative to file-based auth)
YOUTUBE_TOKEN_JSON='{"token": "...", "refresh_token": "...", "token_uri": "https://oauth2.googleapis.com/token", "client_id": "...", "client_secret": "...", "scopes": [...], "universe_domain": "googleapis.com", "account": "", "expiry": "..."}'
